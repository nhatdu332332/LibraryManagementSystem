<Window x:Class="LibraryManagementSystem.WPF.Views.AddSeriesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Series" Height="500" Width="900"
        Background="#1E1E1E" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="3" Margin="0,0,10,0">
            <DockPanel Margin="15">
                <TextBlock DockPanel.Dock="Top" Text="CATEGORY LIST" 
                           FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <DataGrid ItemsSource="{Binding SeriesList}" 
                          SelectedItem="{Binding SelectedSeries}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="White"
                          BorderBrush="#DDD">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding SeriesId}" Width="50"/>
                        <DataGridTextColumn Header="Series Name" Binding="{Binding SeriesName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="3">
            <StackPanel Margin="20">
                <TextBlock Text="SERIES DETAILS" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Series Name" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox Text="{Binding SeriesName, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="5" Margin="0,0,0,15" BorderBrush="#CCC"/>
                <TextBlock Text="Description" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                         Height="120" Padding="5" Margin="0,0,0,20" 
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" BorderBrush="#CCC"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Command="{Binding SaveCommand}" Content="Save / Update" 
                            Background="#333" Foreground="White" Height="30" BorderThickness="0" Margin="0,0,2,0"/>

                    <Button Grid.Column="1" Command="{Binding DeleteCommand}" Content="Delete" 
                            Background="#CC0000" Foreground="White" Height="30" BorderThickness="0" Margin="2,0,0,0"/>
                </Grid>

                <Button Command="{Binding ClearCommand}" Content="Clear Form (Add New)" 
                        Background="#555" Foreground="White" Height="35" BorderThickness="0" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>