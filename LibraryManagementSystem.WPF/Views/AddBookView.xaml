<Window x:Class="LibraryManagementSystem.WPF.Views.AddBookView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm Sách Mới" Height="550" Width="450" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar các nút Add -->
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- ScrollViewer form -->
            <RowDefinition Height="Auto"/>
            <!-- Nút Lưu / Hủy -->
        </Grid.RowDefinitions>

        <!-- Toolbar các nút Add -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="+ Series" Command="{Binding AddSeriesCommand}" Height="30" Width="100" Margin="0,0,5,0"/>
            <Button Content="+ Category" Command="{Binding AddCategoryCommand}" Height="30" Width="100" Margin="0,0,5,0"/>
            <Button Content="+ Author" Command="{Binding AddAuthorCommand}" Height="30" Width="100"/>
        </StackPanel>

        <!-- Title -->
        <TextBlock Grid.Row="1" Text="THÔNG TIN SÁCH MỚI" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#2C3E50"/>

        <!-- ScrollViewer với form -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Tiêu đề sách:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                <TextBlock Text="Tên gốc:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox Text="{Binding OriginalTitle, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                <TextBlock Text="Tóm tắt nội dung:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Summary, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10" 
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Năm XB đầu:" Margin="0,5,0,2" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding FirstPublishYear, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Số tập (Vol):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding VolumeNumber, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,10" Background="#BDC3C7"/>

                <TextBlock Text="Bộ sách (Series):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <ComboBox ItemsSource="{Binding SeriesList}" 
                          SelectedValue="{Binding SelectedSeriesId}"
                          DisplayMemberPath="SeriesName" 
                          SelectedValuePath="SeriesId" 
                          Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Thể loại (Category):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <Border Margin="0,0,0,10" Padding="5" BorderBrush="#EEE" BorderThickness="1">
                    <ScrollViewer Height="100">
                        <ItemsControl ItemsSource="{Binding CategorySelections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <TextBlock Text="Tác giả (Author):" Margin="0,5,0,2" FontWeight="SemiBold"/>
                <Border Margin="0,0,0,10" Padding="5" BorderBrush="#EEE" BorderThickness="1">
                    <ScrollViewer Height="100">
                        <ItemsControl ItemsSource="{Binding AuthorSelections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Nút Lưu / Hủy -->
        <UniformGrid Grid.Row="3" Columns="2" Margin="0,15,0,0">
            <Button Command="{Binding SaveCommand}" Content="Lưu Sách" Height="35" Margin="5"/>
            <Button Name="btnCancel" Content="Hủy bỏ" Height="35" Margin="5" Click="btnCancel_Click"/>
        </UniformGrid>
    </Grid>
</Window>