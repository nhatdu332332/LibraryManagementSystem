<Window x:Class="LibraryManagementSystem.WPF.Views.BookDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết sách" Height="700" Width="1000"
        WindowStartupLocation="CenterOwner">
	<Grid Margin="15">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="4*"/>
			<ColumnDefinition Width="6*"/>
		</Grid.ColumnDefinitions>

		<GroupBox Header="Thông tin tác phẩm (BookWork)" Grid.Column="0" Margin="0,0,10,0">
			<StackPanel Margin="10">
				<TextBlock Text="Tiêu đề chính:" FontWeight="SemiBold" Foreground="Gray"/>
				<TextBlock Text="{Binding WorkTitle}" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10"/>

				<TextBlock Text="Tiêu đề gốc:" FontWeight="SemiBold" Foreground="Gray"/>
				<TextBlock Text="{Binding OriginalTitle}" TextWrapping="Wrap" Margin="0,0,0,10"/>

				<TextBlock Text="Series:" FontWeight="SemiBold" Foreground="Gray"/>
				<TextBlock Text="{Binding SeriesInfo}" Foreground="Blue" Margin="0,0,0,10"/>

				<TextBlock Text="Tác giả:" FontWeight="SemiBold" Foreground="Gray"/>
				<TextBlock Text="{Binding Authors}" TextWrapping="Wrap" Margin="0,0,0,10"/>

				<TextBlock Text="Thể loại:" FontWeight="SemiBold" Foreground="Gray"/>
				<TextBlock Text="{Binding Categories}" TextWrapping="Wrap" Margin="0,0,0,10"/>

				<TextBlock Text="Năm XB đầu:" FontWeight="SemiBold" Foreground="Gray"/>
				<TextBlock Text="{Binding FirstPublishYear}" Margin="0,0,0,10"/>

				<TextBlock Text="Tóm tắt nội dung:" FontWeight="SemiBold" Foreground="Gray"/>
				<TextBlock Text="{Binding Summary}" TextWrapping="Wrap" MaxHeight="200" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
			</StackPanel>
		</GroupBox>

		<GroupBox Header="Thông tin xuất bản &amp; Bản sao (Editions &amp; Copies)" Grid.Column="1">
			<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
				<ItemsControl ItemsSource="{Binding Editions}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border BorderBrush="LightGray" BorderThickness="1" Margin="0,0,0,15" Padding="10" Background="#FAFAFA">
								<StackPanel>
									<TextBlock Text="{Binding EditionTitle}" FontSize="15" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
									<TextBlock Text="{Binding PublisherInfo}" FontStyle="Italic" Margin="0,0,0,10"/>

									<DataGrid ItemsSource="{Binding Copies}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="250">
										<DataGrid.Columns>
											<DataGridTextColumn Header="Mã Barcode" Binding="{Binding Barcode}" Width="120"/>
											<DataGridTextColumn Header="Tình trạng lưu thông" Binding="{Binding CirculationStatus}" Width="130"/>
											<DataGridTextColumn Header="Tình trạng vật lý" Binding="{Binding PhysicalCondition}" Width="120"/>
											<DataGridTextColumn Header="Vị trí kệ" Binding="{Binding ShelfLocation}" Width="100"/>
										</DataGrid.Columns>
									</DataGrid>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</GroupBox>
	</Grid>
</Window>