<Window x:Class="LibraryManagementSystem.WPF.Views.AddAuthorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Tác Giả" Height="550" Width="950" 
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="8" Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1"/>
            </Border.Effect>
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="AUTHOR LIST" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Authors}" SelectedItem="{Binding SelectedAuthor}"
                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0" GridLinesVisibility="None" RowHeight="38">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding AuthorId}" Width="60"/>
                        <DataGridTextColumn Header="Author Name" Binding="{Binding AuthorName}" Width="200"/>
                        <DataGridTextColumn Header="Note / Bio" Binding="{Binding Note}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel Margin="20">
                <TextBlock Text="AUTHOR DETAILS" FontSize="20" FontWeight="Bold" Margin="0,0,0,25"/>

                <TextBlock Text="Author Name" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}" 
                         Height="38" VerticalContentAlignment="Center" Padding="8,0" Margin="0,0,0,20"/>

                <TextBlock Text="Note" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" 
                         Height="150" AcceptsReturn="True" TextWrapping="Wrap" Padding="8" Margin="0,0,0,25"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Content="Save / Update" Command="{Binding SaveOrUpdateCommand}"
                            Background="#2D2D2D" Foreground="White" Height="40" Margin="0,0,5,10"/>
                    <Button Grid.Column="1" Content="Delete" Command="{Binding DeleteCommand}"
                            Background="#D32F2F" Foreground="White" Height="40" Margin="5,0,0,10"/>
                    <Button Grid.Row="1" Grid.ColumnSpan="2" Content="Clear Form (Add New)" 
                            Command="{Binding AddCommand}" Background="#616161" Foreground="White" Height="40"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>