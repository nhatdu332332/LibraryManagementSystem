<UserControl x:Class="LibraryManagementSystem.WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:LibraryManagementSystem.WPF.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="400">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ĐĂNG NHẬP"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <!-- ACCOUNT TYPE -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,20">

            <RadioButton Content="Độc giả"
                         IsChecked="{Binding IsReaderLogin}"
                         GroupName="AccountType"
                         Margin="0,0,30,0"/>

            <RadioButton Content="Nhân viên"
                         IsChecked="{Binding IsEmployeeLogin}"
                         GroupName="AccountType"/>
        </StackPanel>

        <!-- EMAIL -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">

            <TextBlock Text="Email"/>

			<TextBox x:Name="txtEmail" 
             Width="250" Margin="0,5,0,15">
				<TextBox.Text>
					<Binding Path="Email" UpdateSourceTrigger="PropertyChanged">
						<Binding.ValidationRules>
							<helpers:EmailValidationRule />
						</Binding.ValidationRules>
					</Binding>
				</TextBox.Text>
			</TextBox>

		</StackPanel>

        <!-- PASSWORD -->
        <StackPanel Grid.Row="3" Margin="0,0,0,20">

            <TextBlock Text="Mật khẩu"/>

            <PasswordBox x:Name="txtPassword"
                         Width="250"/>

        </StackPanel>

        <!-- LOGIN + REGISTER -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">

            <Button Content="Đăng nhập"
                    Command="{Binding LoginCommand}"
                    CommandParameter="{x:Reference txtPassword}"
                    Width="140"
                    Height="40"
                    Margin="0,0,10,0"/>

            <Button Content="Đăng ký Tài Khoản Mới"
                    Click="ShowRegisterForm"
                    Width="140"
                    Height="40"/>

        </StackPanel>

        <!-- REGISTER FORM -->
		<Border x:Name="RegisterPanel" 
        Grid.Row="1" Grid.RowSpan="7"  Visibility="Collapsed" 
        Background="#F9F9F9" 
        Padding="15" 
        CornerRadius="5" 
        BorderBrush="#DDD" 
        BorderThickness="1" 
        Margin="0,0,0,0"
        Panel.ZIndex="99"       VerticalAlignment="Top"
        MaxHeight="350">
			<ScrollViewer VerticalScrollBarVisibility="Visible">
				<StackPanel>
					<TextBlock Text="ĐĂNG KÝ TÀI KHOẢN" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

					<TextBlock Text="Email"/>
					<TextBox x:Name="txtRegisterEmail" Margin="0,5,0,10">
						<TextBox.Text>
							<Binding Path="RegisterEmail" UpdateSourceTrigger="PropertyChanged">
								<Binding.ValidationRules>
									<helpers:EmailValidationRule/>
								</Binding.ValidationRules>
							</Binding>
						</TextBox.Text>
					</TextBox>

					<TextBlock Text="Mật khẩu"/>
					<PasswordBox x:Name="txtRegisterPassword"
                         helpers:PasswordBoxHelper.BindPassword="True"
                         helpers:PasswordBoxHelper.BoundPassword="{Binding RegisterPassword, Mode=TwoWay}"
                         Margin="0,5,0,10"/>

					<TextBlock Text="Họ tên"/>
					<TextBox x:Name="txtFullName"
                     Text="{Binding RegisterFullName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,10"/>

					<TextBlock Text="Số điện thoại"/>
					<TextBox x:Name="txtPhone"
                     Text="{Binding RegisterPhone, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,10"/>

					<TextBlock Text="Địa chỉ"/>
					<TextBox x:Name="txtAddress"
                     Text="{Binding RegisterAddress, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,5,0,10"
                     AcceptsReturn="True" 
                     Height="50"/>
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
						<Button Content="Xác nhận" 
                        Command="{Binding RegisterCommand}"
                        PreviewMouseDown="CheckRegisterBeforeSubmit"
                        Width="100" Height="30" Margin="0,0,10,0"/>
						<Button Content="Đóng" 
                        Click="HideRegisterForm" 
                        Width="80" Height="30" Background="#E74C3C" Foreground="White"/>
					</StackPanel>
				</StackPanel>
			</ScrollViewer>
		</Border>

		<TextBlock Grid.Row="7"
                   Text="{Binding StatusMessage}"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>

    </Grid>
</UserControl>