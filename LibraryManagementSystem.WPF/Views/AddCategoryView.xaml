<Window x:Class="LibraryManagementSystem.WPF.Views.AddCategoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Quản Lý Thể Loại" Height="500" Width="900" 
        Background="#1E1E1E">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="5" Margin="5">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="CATEGORY LIST" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding Categories}" 
                          SelectedItem="{Binding SelectedCategory}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          Background="White" 
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EEEEEE">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding CategoryId}" Width="50"/>
                        <DataGridTextColumn Header="Series Name" Binding="{Binding CategoryName}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="5" Margin="5">
            <StackPanel Margin="15">
                <TextBlock Text="SERIES DETAILS" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Series Name" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}" 
                         Padding="5" Margin="0,0,0,15" BorderBrush="#DDDDDD"/>

                <TextBlock Text="Description" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                         Height="120" AcceptsReturn="True" TextWrapping="Wrap" 
                         Padding="5" Margin="0,0,0,20" BorderBrush="#DDDDDD"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Content="Save / Update" 
                            Command="{Binding SaveOrUpdateCommand}"
                            Background="#333333" Foreground="White" Height="35" Margin="0,0,5,5" BorderThickness="0"/>

                    <Button Grid.Row="0" Grid.Column="1" Content="Delete" 
                            Command="{Binding DeleteCommand}"
                            Background="#CC0000" Foreground="White" Height="35" Margin="5,0,0,5" BorderThickness="0"/>

					<Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                    Content="Clear Form (Add New)"
                    Command="{Binding ClearCommand}"
					Background="#555555" Foreground="White" Height="35" Margin="0,5,0,0" BorderThickness="0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>