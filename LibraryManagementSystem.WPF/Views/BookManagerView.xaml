<UserControl x:Class="LibraryManagementSystem.WPF.Views.BookManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="450" Width="800">

    <Grid Grid.Row="0" Margin="0,0,0,10" Background="#f5f5f5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- ROW 1: SEARCH + BUTTON -->
        <Grid Grid.Row="0" Margin="0,0,0,10" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX -->
            <Border Grid.Column="0"
            Background="White"
            CornerRadius="8"
            Padding="5"
            Margin="0,0,10,0"
            VerticalAlignment="Center"
            BorderBrush="#ddd"
            BorderThickness="1">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Width="200"
                 Height="30"
                 BorderThickness="0"
                 Background="Transparent"
                 VerticalContentAlignment="Center"
                 FontSize="14"
                 Padding="5,0"/>
            </Border>

            <!-- SEARCH BUTTON -->
            <Button Grid.Column="1"
            Content="Search"
            Command="{Binding SearchCommand}"
            Width="90"
            Height="32"
            Margin="0,0,10,0"
            Background="#4CAF50"
            Foreground="White"
            BorderThickness="0"
            Cursor="Hand"
            VerticalAlignment="Center">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- ADD BUTTON -->
            <Button Grid.Column="3"
            Content="+ Add"
            Width="100"
            Height="32"
            Background="#2196F3"
            Foreground="White"
            BorderThickness="0"
            Cursor="Hand"
            VerticalAlignment="Center"
                    Command="{Binding AddCommand}" >
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- ROW 2: DATA GRID -->
        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  ItemsSource="{Binding BookWorks}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding WorkId}" Width="50"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Original Title" Binding="{Binding OriginalTitle}" Width="*"/>
                <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*"/>
                <DataGridTextColumn Header="Year" Binding="{Binding FirstPublishYear}" Width="80"/>
                <DataGridTextColumn Header="SeriesName" Binding="{Binding Series.SeriesName}" Width="120"/>
                <DataGridTextColumn Header="Volume" Binding="{Binding VolumeNumber}" Width="80"/>

                <!-- ACTION COLUMN -->
                <DataGridTemplateColumn Header="Action" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                
                                <Button Content="Edit"
        Margin="2"
        Width="50"
        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
        CommandParameter="{Binding}"/>
                                <Button Content="Detail" Margin="2" Width="50"
                                        Command="{Binding DataContext.DetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding WorkId}"/>
                                
                                <Button Content="Delete"
        Margin="2"
        Width="60"
        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
        CommandParameter="{Binding WorkId}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>