<Window x:Class="LibraryManagementSystem.WPF.Views.AddBookCopy"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add Book Copy" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="ADD BOOK COPY"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Form -->
        <StackPanel Grid.Row="1">

            <!-- Book Edition -->
            <TextBlock Text="ISBN"/>
            <ComboBox ItemsSource="{Binding BookEditions}"
                      SelectedItem="{Binding SelectedEdition}"
                      DisplayMemberPath="ISBN"
                      Margin="0,5,0,15"
                      Height="30"/>

            <!-- Barcode -->
            <TextBlock Text="Barcode"/>
            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     Margin="0,5,0,15"/>

            <!-- Circulation Status -->
            <TextBlock Text="Circulation Status"/>
            <ComboBox ItemsSource="{Binding StatusList}"
                      SelectedItem="{Binding CirculationStatus}"
                      Height="30"
                      Margin="0,5,0,15"/>

            <!-- Physical Condition -->
            <TextBlock Text="Physical Condition"/>
            <ComboBox ItemsSource="{Binding ConditionList}"
                      SelectedItem="{Binding PhysicalCondition}"
                      Height="30"
                      Margin="0,5,0,15"/>

            <!-- Shelf -->
            <TextBlock Text="Shelf Location"/>
            <TextBox Text="{Binding ShelfLocation, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     Margin="0,5,0,15"/>

            <!-- Added Date -->
            <TextBlock Text="Added Date"/>
            <DatePicker SelectedDate="{Binding AddedDate}"
                        Margin="0,5,0,15"/>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Save"
                    Width="100"
                    Height="35"
                    Margin="5"
                    Command="{Binding SaveAndCloseCommand}"/>

            <Button Content="Save &amp; Add Condition"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Command="{Binding SaveAndAddCommand}"/>

            <Button Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="5"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>