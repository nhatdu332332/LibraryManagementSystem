<Window x:Class="LibraryManagementSystem.WPF.Views.BookEditionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Book Edition" Height="1000" Width="1500" 
        Background="#121212" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="20">
        <Border Background="White" CornerRadius="15" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.15"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="CREATE EDITION" FontSize="24" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <TextBlock Text="ISBN *" Foreground="#666666" FontSize="12" Margin="0,0,0,5"/>
                <TextBox Text="{Binding ISBN, UpdateSourceTrigger=PropertyChanged}" 
                         Height="42" VerticalContentAlignment="Center" Padding="12,0" Margin="0,0,0,20" 
                         FontSize="14" BorderBrush="#DDDDDD"/>

                <TextBlock Text="Publisher *" Foreground="#666666" FontSize="12" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Publishers}" 
                          SelectedItem="{Binding SelectedPublisher}"
                          DisplayMemberPath="PublisherName" 
                          Height="42" Margin="0,0,0,25" VerticalContentAlignment="Center"/>

                <Separator Margin="0,0,0,25" Background="#F0F0F0"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Publish Year" Foreground="#666666" FontSize="11" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PublishYear}" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,18"/>

                        <TextBlock Text="Page Count" Foreground="#666666" FontSize="11" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PageCount}" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,18"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Edition Number" Foreground="#666666" FontSize="11" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding EditionNumber}" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,18"/>

                        <TextBlock Text="Language" Foreground="#666666" FontSize="11" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Language}" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,18"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Format (Paperback, E-book...)" Foreground="#666666" FontSize="11" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Format}" Height="38" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,30"/>

                <UniformGrid Columns="3" Height="45">
                    <Button Content="SAVE" Command="{Binding SaveCommand}" 
                            Background="#1A1A1A" Foreground="White" FontWeight="Bold" Margin="0,0,8,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="SAVE &amp; ADD" Command="{Binding SaveAndAddCommand}"
                            Background="#2D8542" Foreground="White" FontWeight="Bold" Margin="0,0,8,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="CANCEL" Command="{Binding ClearCommand}" 
                            Background="#F5F5F5" BorderBrush="#EEEEEE" BorderThickness="1" Margin="8,0,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>